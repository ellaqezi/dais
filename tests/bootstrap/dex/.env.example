# Environment configuration for devexnet
# Copy to .env and fill in local values. Never commit .env.

# Runtime
LOG_LEVEL=INFO        # DEBUG | INFO | WARNING | ERROR
DRY_RUN=false         # true = print planned actions without executing

# DAIS integration (optional — for running full agent pipeline)
# DAIS_ROOT=../../     # path to DAIS repo root relative to this project

# Model config (override default tier per prompt)
# MODEL_HAIKU=claude-haiku-4
# MODEL_SONNET=claude-sonnet-4
# MODEL_OPUS=claude-opus-4
